---
import Layout from '@layouts/Layout.astro';
import PageHeader from '@components/PageHeader.astro';
import { useTranslations } from '@i18n/utils';

const t = useTranslations('en');
---

<Layout
  title={`${t.groupsPage.pageTitle} | ${t.meta.siteTitle}`}
  description={t.meta.siteDescription}
  locale="en"
  canonicalPath="/en/groups"
>
  <PageHeader title={t.groupsPage.pageTitle} />

  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 space-y-12">
      <div class="animate-on-scroll rounded-2xl border border-(--border-color) bg-(--bg-card) p-8 shadow-sm sm:p-10">
        <p class="text-base leading-relaxed text-(--text-secondary)">
          {t.groupsPage.safeBeginningsText}
        </p>
      </div>

      <div class="animate-on-scroll stagger-1 rounded-2xl border border-(--border-color) bg-(--bg-card) p-8 shadow-sm sm:p-10">
        <h2 class="mb-4 font-heading text-2xl font-bold text-(--text-primary)">
          {t.groupsPage.filmClubTitle}
        </h2>
        <p class="text-base leading-relaxed text-(--text-secondary)">
          {t.groupsPage.filmClubText}
        </p>
        <div class="mt-6 space-y-2">
          {t.groupsPage.filmClubEvents.map((event) => (
            <div class="flex items-center gap-3 rounded-lg bg-(--bg-secondary) px-4 py-3 text-sm text-(--text-secondary)">
              <svg class="size-4 flex-shrink-0 text-(--bg-accent)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
              </svg>
              {event}
            </div>
          ))}
        </div>
        <p class="mt-4 text-sm font-medium text-(--text-muted)">
          {t.groupsPage.filmClubLocation}
        </p>
      </div>

      <div class="animate-on-scroll stagger-2 rounded-2xl border border-(--border-color) bg-(--bg-card) p-8 shadow-sm sm:p-10">
        <div class="mb-4">
          <p class="font-heading text-lg text-(--text-secondary)">{t.groupsPage.thematicGroupTitle}</p>
          <p class="font-heading text-lg text-(--text-secondary)">{t.groupsPage.thematicGroupSubtitle}</p>
          <h2 class="mt-2 font-heading text-2xl font-bold text-(--text-primary)">{t.groupsPage.thematicGroupIntro}</h2>
        </div>
        <div class="whitespace-pre-line text-base leading-relaxed text-(--text-secondary)">
          {t.groupsPage.thematicGroupDescription}
        </div>
        <div class="mt-8">
          <h3 class="mb-4 font-heading text-lg font-semibold text-(--text-primary)">Topics:</h3>
          <ol class="space-y-2">
            {t.groupsPage.thematicGroupTopics.map((topic, i) => (
              <li class="flex gap-3 text-sm text-(--text-secondary)">
                <span class="flex-shrink-0 font-semibold text-(--bg-accent)">{i + 1}.</span>
                {topic}
              </li>
            ))}
          </ol>
        </div>
        <div class="mt-8 text-sm leading-relaxed text-(--text-secondary)">
          <p>{t.groupsPage.thematicGroupMethod}</p>
        </div>
        <div class="mt-6 rounded-xl bg-(--bg-secondary) p-4">
          <p class="text-sm font-medium text-(--text-primary)">{t.groupsPage.thematicGroupSchedule}</p>
        </div>
        <p class="mt-4 text-xs italic text-(--text-muted)">{t.groupsPage.thematicGroupNote}</p>
      </div>
    </div>
  </section>
</Layout>
