---
import Layout from '@layouts/Layout.astro';
import PageHeader from '@components/PageHeader.astro';
import { useTranslations } from '@i18n/utils';

const t = useTranslations('hu');
---

<Layout
  title={`${t.safeBeginnings.pageTitle} | ${t.meta.siteTitle}`}
  description={t.meta.siteDescription}
  locale="hu"
  canonicalPath="/biztonsagos-kezdetek"
>
  <PageHeader title={t.safeBeginnings.pageTitle} />

  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="animate-on-scroll rounded-2xl border border-(--border-color) bg-(--bg-card) p-8 shadow-sm sm:p-10">
        <p class="text-base leading-relaxed text-(--text-secondary)">
          {t.safeBeginnings.content}
        </p>
        <div class="mt-8 rounded-xl bg-(--bg-secondary) p-6">
          <p class="text-sm font-semibold text-(--text-primary)">Érdeklődés:</p>
          <div class="mt-2 space-y-1">
            <a href={`mailto:${t.safeBeginnings.contactEmail}`} class="block text-sm text-(--text-secondary) hover:text-(--text-primary) transition-colors">
              {t.safeBeginnings.contactEmail}
            </a>
            <a href={`tel:+36308724413`} class="block text-sm text-(--text-secondary) hover:text-(--text-primary) transition-colors">
              {t.safeBeginnings.contactPhone}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
