---
import Layout from '@layouts/Layout.astro';
import PageHeader from '@components/PageHeader.astro';
import { useTranslations } from '@i18n/utils';

const t = useTranslations('hu');
---

<Layout
  title={`${t.efPastoralCare.pageTitle} | ${t.meta.siteTitle}`}
  description={t.meta.siteDescription}
  locale="hu"
  canonicalPath="/ef-lelkigondozas"
>
  <PageHeader title={t.efPastoralCare.pageTitle} />

  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <p class="animate-on-scroll text-base leading-relaxed text-(--text-secondary)">
        {t.efPastoralCare.intro}
      </p>

      <p class="animate-on-scroll stagger-1 mt-8 font-heading text-lg font-semibold text-(--text-primary)">
        {t.efPastoralCare.methodsIntro}
      </p>

      <div class="mt-8 space-y-6">
        {t.efPastoralCare.methods.map((method, i) => (
          <div class={`animate-on-scroll stagger-${Math.min(i + 1, 5)} rounded-2xl border border-(--border-color) bg-(--bg-card) p-6 transition-shadow hover:shadow-md sm:p-8`}>
            <h3 class="mb-3 font-heading text-xl font-semibold text-(--text-primary)">
              {method.title}
            </h3>
            <p class="text-sm leading-relaxed text-(--text-secondary)">
              {method.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
