---
import Layout from '@layouts/Layout.astro';
import PageHeader from '@components/PageHeader.astro';
import { useTranslations } from '@i18n/utils';

const t = useTranslations('hu');
---

<Layout
  title={`${t.pricingPage.pageTitle} | ${t.meta.siteTitle}`}
  description={t.meta.siteDescription}
  locale="hu"
  canonicalPath="/arak-es-keretek"
>
  <PageHeader title={t.pricingPage.pageTitle} />

  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-6 sm:grid-cols-2">
        <div class="animate-on-scroll rounded-2xl border border-(--border-color) bg-(--bg-card) p-8 text-center shadow-sm transition-shadow hover:shadow-md">
          <h2 class="font-heading text-lg font-semibold text-(--text-primary)">
            {t.pricingPage.individualTitle}
          </h2>
          <p class="mt-4 font-heading text-3xl font-bold text-(--bg-accent)">
            {t.pricingPage.individualPrice}
          </p>
          <p class="mt-2 text-sm text-(--text-muted)">
            {t.pricingPage.individualDuration}
          </p>
        </div>

        <div class="animate-on-scroll stagger-1 rounded-2xl border border-(--border-color) bg-(--bg-card) p-8 text-center shadow-sm transition-shadow hover:shadow-md">
          <h2 class="font-heading text-lg font-semibold text-(--text-primary)">
            {t.pricingPage.couplesTitle}
          </h2>
          <p class="mt-4 font-heading text-3xl font-bold text-(--bg-accent)">
            {t.pricingPage.couplesPrice}
          </p>
          <p class="mt-2 text-sm text-(--text-muted)">
            {t.pricingPage.couplesDuration}
          </p>
        </div>
      </div>

      <div class="animate-on-scroll stagger-2 mt-10 space-y-6 rounded-2xl border border-(--border-color) bg-(--bg-card) p-8 shadow-sm sm:p-10">
        <p class="text-base leading-relaxed text-(--text-secondary)">
          {t.pricingPage.description}
        </p>
        <p class="text-base leading-relaxed text-(--text-secondary)">
          {t.pricingPage.cancellationPolicy}
        </p>
        <p class="text-sm italic text-(--text-muted)">
          {t.pricingPage.disclaimer}
        </p>
      </div>
    </div>
  </section>
</Layout>
