---
import Layout from '@layouts/Layout.astro';
import PageHeader from '@components/PageHeader.astro';
import { useTranslations } from '@i18n/utils';

const t = useTranslations('hu');
const telHref = `tel:${t.groupsPage.contactPhone.replace(/[^+\d]/g, '')}`;
---

<Layout
  title={`${t.groupsPage.pageTitle} | ${t.meta.siteTitle}`}
  description={t.meta.siteDescription}
  locale="hu"
  canonicalPath="/csoportok"
>
  <PageHeader title={t.groupsPage.pageTitle} />

  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="animate-on-scroll rounded-2xl border border-(--border-color) bg-(--bg-card) p-8 shadow-sm sm:p-10">
        <h2 class="mb-6 font-heading text-2xl font-bold text-(--text-primary)">
          {t.groupsPage.listIntro}
        </h2>

        <ul class="space-y-3">
          {t.groupsPage.groups.map((group) => (
            <li class="flex gap-3 text-base leading-relaxed text-(--text-secondary)">
              <span class="mt-2 inline-block size-2 flex-shrink-0 rounded-full bg-(--bg-accent)"></span>
              <span>{group}</span>
            </li>
          ))}
        </ul>

        <p class="mt-6 text-base italic text-(--text-secondary)">
          {t.groupsPage.joinInfo}
        </p>

        <div class="mt-8 border-t border-(--border-color) pt-6">
          <p class="text-sm font-semibold uppercase tracking-wide text-(--text-muted)">
            {t.groupsPage.contactLabel}
          </p>
          <div class="mt-3 space-y-2">
            <a
              href={`mailto:${t.groupsPage.contactEmail}`}
              class="block text-(--text-secondary) transition-colors hover:text-(--text-primary)"
            >
              {t.groupsPage.contactEmail}
            </a>
            <a
              href={telHref}
              class="block text-(--text-secondary) transition-colors hover:text-(--text-primary)"
            >
              {t.groupsPage.contactPhone}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
