---
import Layout from '@layouts/Layout.astro';
import PageHeader from '@components/PageHeader.astro';
import { useTranslations } from '@i18n/utils';

const t = useTranslations('hu');
---

<Layout
  title={`${t.newsPage.pageTitle} | ${t.meta.siteTitle}`}
  description={t.meta.siteDescription}
  locale="hu"
  canonicalPath="/aktualitasok"
>
  <PageHeader title={t.newsPage.pageTitle} />

  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="animate-on-scroll rounded-2xl border border-(--border-color) bg-(--bg-card) p-8 shadow-sm sm:p-10">
        <p class="mb-6 text-base text-(--text-secondary)">
          {t.newsPage.scheduleIntro}
        </p>

        <div class="mb-8 space-y-2">
          <a href={`tel:+36308724413`} class="block text-(--text-secondary) hover:text-(--text-primary) transition-colors">
            {t.newsPage.phone}
          </a>
          <a href={`mailto:${t.newsPage.email}`} class="block text-(--text-secondary) hover:text-(--text-primary) transition-colors">
            {t.newsPage.email}
          </a>
        </div>

        <div class="grid gap-6 sm:grid-cols-2">
          {t.newsPage.locations.map((loc) => (
            <div class="rounded-xl bg-(--bg-secondary) p-6">
              <h3 class="font-heading text-xl font-semibold text-(--text-primary)">
                {loc.city}
              </h3>
              <p class="mt-2 text-sm text-(--text-secondary)">{loc.address}</p>
              <p class="mt-2 text-sm font-medium text-(--bg-accent)">{loc.days}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
