---
import { CONTACT } from '@config/site';
import contactHeads from '@assets/images/contact-heads.png';

interface Props {
  title: string;
  formLabels: {
    name: string;
    email: string;
    phone: string;
    location: string;
    locationPlaceholder: string;
    locationOptions: readonly string[];
    message: string;
    send: string;
    success: string;
  };
  sectionId: string;
}

const { title, formLabels, sectionId } = Astro.props;
---

<section id={sectionId} class="scroll-mt-20 bg-(--bg-secondary) py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mb-12 flex items-center justify-center gap-6">
      <img
        src={contactHeads.src}
        alt=""
        width="100"
        height="110"
        class="hidden rounded-lg sm:block"
        loading="lazy"
        decoding="async"
      />
      <h2 class="animate-on-scroll font-heading text-4xl font-bold text-(--text-primary) sm:text-5xl">
        {title}
      </h2>
    </div>

    <div class="grid gap-12 lg:grid-cols-2">
      <div class="animate-on-scroll space-y-6">
        <a
          href={`mailto:${CONTACT.email}`}
          class="flex items-center gap-3 text-lg text-(--text-secondary) transition-colors hover:text-(--text-primary)"
        >
          <svg class="size-5 flex-shrink-0 text-(--bg-accent)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          {CONTACT.email}
        </a>
        <a
          href={`tel:${CONTACT.phone}`}
          class="flex items-center gap-3 text-lg text-(--text-secondary) transition-colors hover:text-(--text-primary)"
        >
          <svg class="size-5 flex-shrink-0 text-(--bg-accent)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          {CONTACT.phoneDisplay}
        </a>
        <p class="flex items-center gap-3 text-lg font-semibold text-(--text-primary)">
          <svg class="size-5 flex-shrink-0 text-(--bg-accent)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
          </svg>
          {CONTACT.name}
        </p>
      </div>

      <form
        class="animate-on-scroll stagger-2 space-y-4"
        action={`mailto:${CONTACT.email}`}
        method="post"
        enctype="text/plain"
      >
        <div>
          <label for="contact-name" class="mb-1.5 block text-sm font-medium text-(--text-secondary)">{formLabels.name} *</label>
          <input
            type="text"
            id="contact-name"
            name="name"
            required
            class="w-full rounded-xl border border-(--border-color) bg-(--bg-card) px-4 py-3 text-sm text-(--text-primary) outline-none transition-colors focus:border-(--border-accent) focus:ring-2 focus:ring-(--border-accent)/20"
          />
        </div>
        <div>
          <label for="contact-email" class="mb-1.5 block text-sm font-medium text-(--text-secondary)">{formLabels.email} *</label>
          <input
            type="email"
            id="contact-email"
            name="email"
            required
            class="w-full rounded-xl border border-(--border-color) bg-(--bg-card) px-4 py-3 text-sm text-(--text-primary) outline-none transition-colors focus:border-(--border-accent) focus:ring-2 focus:ring-(--border-accent)/20"
          />
        </div>
        <div>
          <label for="contact-phone" class="mb-1.5 block text-sm font-medium text-(--text-secondary)">{formLabels.phone}</label>
          <input
            type="tel"
            id="contact-phone"
            name="phone"
            class="w-full rounded-xl border border-(--border-color) bg-(--bg-card) px-4 py-3 text-sm text-(--text-primary) outline-none transition-colors focus:border-(--border-accent) focus:ring-2 focus:ring-(--border-accent)/20"
          />
        </div>
        <div>
          <label for="contact-location" class="mb-1.5 block text-sm font-medium text-(--text-secondary)">{formLabels.location}</label>
          <select
            id="contact-location"
            name="location"
            class="w-full rounded-xl border border-(--border-color) bg-(--bg-card) px-4 py-3 text-sm text-(--text-primary) outline-none transition-colors focus:border-(--border-accent) focus:ring-2 focus:ring-(--border-accent)/20"
          >
            <option value="">{formLabels.locationPlaceholder}</option>
            {formLabels.locationOptions.map((opt) => (
              <option value={opt}>{opt}</option>
            ))}
          </select>
        </div>
        <div>
          <label for="contact-message" class="mb-1.5 block text-sm font-medium text-(--text-secondary)">{formLabels.message}</label>
          <textarea
            id="contact-message"
            name="message"
            rows={4}
            class="w-full resize-none rounded-xl border border-(--border-color) bg-(--bg-card) px-4 py-3 text-sm text-(--text-primary) outline-none transition-colors focus:border-(--border-accent) focus:ring-2 focus:ring-(--border-accent)/20"
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full rounded-xl bg-(--bg-accent) px-6 py-3 text-sm font-semibold text-(--text-on-accent) transition-all hover:opacity-90 hover:shadow-md cursor-pointer"
        >
          {formLabels.send}
        </button>
      </form>
    </div>
  </div>
</section>
