---
import type { Locale } from '@config/site';
import { FEATURES } from '@config/features';
import { getAlternateLocaleHref } from '@config/navigation';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;

if (!FEATURES.i18n) return;

const targetLocale: Locale = locale === 'hu' ? 'en' : 'hu';
const targetHref = getAlternateLocaleHref(currentPath, targetLocale);
const targetLabel = targetLocale.toUpperCase();
---

<a
  href={targetHref}
  class="rounded-full border border-(--border-color) bg-(--bg-card) px-3 py-1.5 text-sm font-semibold text-(--text-secondary) transition-all duration-200 hover:border-(--border-accent) hover:shadow-sm"
  aria-label={`Switch to ${targetLocale === 'hu' ? 'Hungarian' : 'English'}`}
>
  {targetLabel}
</a>
