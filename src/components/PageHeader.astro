---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="bg-(--bg-accent) py-16 sm:py-20">
  <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
    <h1
      class="font-heading text-4xl font-bold text-(--text-on-accent) sm:text-5xl"
      style="animation: fade-in 0.6s ease both;"
    >
      {title}
    </h1>
    {subtitle && (
      <p
        class="mx-auto mt-4 max-w-2xl text-base text-(--text-on-accent)/70"
        style="animation: fade-in 0.6s ease 0.2s both;"
      >
        {subtitle}
      </p>
    )}
  </div>
</section>
