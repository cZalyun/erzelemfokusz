---
import quoteImage from '@assets/images/quote-image.jpg';

interface Props {
  title: string;
  focusTitle: string;
  focusTags: readonly string[];
  charTitle: string;
  charTags: readonly string[];
  specializationsTitle: string;
  specializations: readonly string[];
  sectionId: string;
}

const { title, focusTitle, focusTags, charTitle, charTags, specializationsTitle, specializations, sectionId } = Astro.props;
---

<section id={sectionId} class="scroll-mt-20 py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <img
        src={quoteImage.src}
        alt="ÉrzelemFókusz"
        width={quoteImage.width}
        height={quoteImage.height}
        class="animate-on-scroll mx-auto mb-12 max-w-md rounded-2xl shadow-lg"
        loading="lazy"
        decoding="async"
      />
      <h2 class="animate-on-scroll font-heading text-4xl font-bold text-(--text-primary) sm:text-5xl">
        {title}
      </h2>
    </div>

    <div class="grid gap-12 lg:grid-cols-2">
      <div class="animate-on-scroll">
        <h3 class="mb-6 font-heading text-xl font-semibold text-(--text-primary)">
          {focusTitle}
        </h3>
        <div class="flex flex-wrap gap-2">
          {focusTags.map((tag) => (
            <span class="rounded-full border border-(--border-accent) bg-(--bg-accent)/5 px-4 py-2 text-sm font-medium text-(--text-secondary) transition-colors hover:bg-(--bg-accent)/10">
              #{tag}
            </span>
          ))}
        </div>
      </div>

      <div class="animate-on-scroll stagger-2">
        <h3 class="mb-6 font-heading text-xl font-semibold text-(--text-primary)">
          {charTitle}
        </h3>
        <div class="flex flex-wrap gap-2">
          {charTags.map((tag) => (
            <span class="rounded-full border border-(--color-gold-500)/30 bg-(--color-gold-500)/5 px-4 py-2 text-sm font-medium text-(--text-secondary) transition-colors hover:bg-(--color-gold-500)/10">
              #{tag}
            </span>
          ))}
        </div>
      </div>
    </div>

    <div class="animate-on-scroll stagger-3 mt-16">
      <h3 class="mb-8 text-center font-heading text-2xl font-semibold text-(--text-primary)">
        {specializationsTitle}
      </h3>
      <ul class="grid gap-4 sm:grid-cols-2">
        {specializations.map((item) => (
          <li class="flex gap-3 rounded-xl border border-(--border-color) bg-(--bg-card) p-4 transition-shadow hover:shadow-md">
            <div class="mt-1 flex-shrink-0">
              <div class="size-2 rounded-full bg-(--bg-accent)"></div>
            </div>
            <span class="text-sm leading-relaxed text-(--text-secondary)">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
